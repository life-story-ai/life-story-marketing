---
import LandingPage from '../components/LandingPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLandingPageVariantContent } from '../content/site';

const content = getLandingPageVariantContent('childhoodBook');
const canonicalPath = '/childhood-book';
---

<BaseLayout
  locale="en"
  title={content.meta.title}
  description={content.meta.description}
  canonicalPath={canonicalPath}
  alternateLinks={[
    { hreflang: 'en', href: canonicalPath },
    { hreflang: 'x-default', href: canonicalPath },
  ]}
>
  <LandingPage content={content} />
</BaseLayout>
