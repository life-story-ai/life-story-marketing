---
import LandingPage from '../components/LandingPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLandingPageContent } from '../content/site';

const content = getLandingPageContent('en');
const title = 'Create a Childhood Memory Book – Life Story AI';
const description = "Capture your child's early years in a beautiful printed book. Record milestones, funny moments, and family memories with the help of an AI biographer.";
---

<BaseLayout locale="en" title={title} description={description} canonicalPath="/childhood-book">
  <LandingPage content={content} />
</BaseLayout>
