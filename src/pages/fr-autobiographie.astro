---
import LandingPage from '../components/LandingPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLandingPageContent } from '../content/site';

const content = getLandingPageContent('fr');
const title = 'Écrire son autobiographie avec l\'IA – Life Story AI';
const description = 'Écrivez votre autobiographie avec l\'aide d\'un biographe IA. Répondez à des questions par voix ou texte et recevez un livre imprimé de votre histoire de vie en quelques semaines.';
---

<BaseLayout locale="fr" title={title} description={description} canonicalPath="/autobiographie">
  <LandingPage content={content} />
</BaseLayout>
