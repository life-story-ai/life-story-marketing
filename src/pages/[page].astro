---
import StaticPage from '../components/StaticPage.astro';
import { getStaticPageContent, staticPageKeys } from '../content/static-pages';

export function getStaticPaths() {
  return staticPageKeys.filter((page) => page !== 'mentions-legales').map((page) => ({
    params: { page },
    props: {
      content: getStaticPageContent('en', page),
    },
  }));
}

const { content } = Astro.props;
---

<StaticPage content={content} />
