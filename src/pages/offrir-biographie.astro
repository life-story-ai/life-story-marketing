---
import LandingPage from '../components/LandingPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLandingPageContent } from '../content/site';

const content = getLandingPageContent('fr');
const title = 'Offrir une biographie – Idée cadeau originale – Life Story AI';
const description = 'Offrez un cadeau unique : un livre biographique imprimé. Parfait pour un parent, un grand-parent ou toute personne avec une histoire à raconter. Carte cadeau imprimable incluse.';
---

<BaseLayout locale="fr" title={title} description={description} canonicalPath="/fr-cadeau-biographie">
  <LandingPage content={content} />
</BaseLayout>
