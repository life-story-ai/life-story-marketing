---
import type { LandingPageContent, Locale } from '../content/types';
import { normalizeSiteHref, withConfiguredSiteHref } from '../lib/site-links.js';
import SocialIcon from './SocialIcon.astro';
import UiIcon from './UiIcon.astro';

interface Props {
  content: LandingPageContent['footer'];
  locale: Locale;
  anchorHrefPrefix?: string;
}

const { content, locale, anchorHrefPrefix = '' } = Astro.props;
const alternateLanguageHref = withConfiguredSiteHref(content.alternateLanguage.href);
const [companyLine = '', addressLine = '', emailLine = '', ...detailLines] = content.lines;

function resolveHref(href: string) {
  return normalizeSiteHref(locale, href, { anchorHrefPrefix });
}
---

<footer id="footer" class="section section--footer section--center dark" style="background-color:#fff;padding-bottom:15px;padding-top:15px;--pdx-min-height:0px;--wr-max:1440px">
  <div class="wr">
    <div class="footer">
      <div class="footer__primary">
        <span>
          {companyLine}<br />
          {addressLine}<br />
          Email: <a href={`mailto:${emailLine}`}>{emailLine}</a>
          {detailLines.map((line) => (
            <>
              <br />
              {line}
            </>
          ))}
        </span>
        <ul class="footer__social">
          {content.socialLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noreferrer noopener" class="color-2">
                <SocialIcon platform={link.platform} />
              </a>
            </li>
          ))}
        </ul>
        <nav class="footer__linkRow">
          <div class="languagePicker footerLP js-language-picker">
            <ul class="options" style="background-color:rgb(255, 255, 255)">
              <li class="arrow-down" style="border-top-color:rgb(255, 255, 255)"></li>
              <li class="option">
                <a style="color:#222" href={alternateLanguageHref}>
                  {content.alternateLanguage.label}
                </a>
              </li>
            </ul>
            <button class="activeLanguage link js-language-trigger" type="button">
              <UiIcon name="globe" />
              <span>{content.currentLanguage}</span>
            </button>
          </div>
        </nav>
      </div>
      <div class="footer__linkGroups">
        {content.legalLinks.map((group) => (
          <ul class="footer__linkGroup">
            <li class="weight-text">{group.title ?? ''}</li>
            {group.links.map((link) => (
              <a href={resolveHref(link.href)}>{link.label}</a>
            ))}
          </ul>
        ))}
      </div>
    </div>
  </div>
</footer>
